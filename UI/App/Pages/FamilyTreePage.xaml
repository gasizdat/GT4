<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GT4.UI.Pages.FamilyTreePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GT4.UI.Components"
    xmlns:resources="clr-namespace:GT4.UI.Resources;assembly=GT4.UI.Resources"
    x:Name="Root"
    Title="{Binding PageTitle, Source={x:Reference Root}}">

  <ContentPage.ToolbarItems>
    <ToolbarItem
        Command="{Binding PageCommand, Source={x:Reference Root}}"
        CommandParameter="OpenPerson"
        Order="Secondary"
        Text="{Binding OpenPersonToolbarItemName, Source={x:Reference Root}}" />
    <ToolbarItem
        Command="{Binding PageCommand, Source={x:Reference Root}}"
        CommandParameter="Refresh"
        Order="Secondary"
        Text="{x:Static resources:UIStrings.MenuItemNameRefresh}" />
  </ContentPage.ToolbarItems>

  <components:PageLayout>

    <components:PageLayout.Header>
      <Grid
          ColumnDefinitions="*, Auto"
          RowDefinitions="Auto">
        <Label
            Grid.Column="0"
            Style="{StaticResource PageSubtitle}"
            Text="{x:Static resources:UIStrings.HintFamilyTreePage}"
            VerticalOptions="Center" />

        <HorizontalStackLayout
            Grid.Column="1"
            Spacing="{StaticResource PageContentSpacing}">
          <Label
              Style="{StaticResource FieldName}"
              Text="{x:Static resources:UIStrings.LblRelatives}"
              VerticalOptions="Center" />
          <Switch
              IsToggled="{Binding IncludeCollaterals, Source={x:Reference Root}}"
              VerticalOptions="Center" />
        </HorizontalStackLayout>
      </Grid>
    </components:PageLayout.Header>

    <components:PageLayout.Body>
      <Grid>
        <ScrollView
            x:Name="Scroller"
            Orientation="Both">
          <Grid
              x:Name="Canvas"
              BackgroundColor="Transparent"
              HorizontalOptions="Fill"
              VerticalOptions="Start">
            <GraphicsView
                x:Name="Connectors"
                HorizontalOptions="Center"
                InputTransparent="True" />
            <AbsoluteLayout x:Name="Nodes" />
          </Grid>
        </ScrollView>

        <!--  Pinned over the canvas: load another generation of ancestors (top) or descendants (bottom).  -->
        <Button
            Margin="0,8"
            Padding="16,6"
            Command="{Binding PageCommand, Source={x:Reference Root}}"
            CommandParameter="LoadAncestors"
            HorizontalOptions="Center"
            IsVisible="{Binding CanLoadMoreAncestors, Source={x:Reference Root}}"
            Text="{x:Static resources:UIStrings.BtnNameLoadAncestors}"
            VerticalOptions="Start" />
        <Button
            Margin="0,8"
            Padding="16,6"
            Command="{Binding PageCommand, Source={x:Reference Root}}"
            CommandParameter="LoadDescendants"
            HorizontalOptions="Center"
            IsVisible="{Binding CanLoadMoreDescendants, Source={x:Reference Root}}"
            Text="{x:Static resources:UIStrings.BtnNameLoadDescendants}"
            VerticalOptions="End" />
      </Grid>
    </components:PageLayout.Body>

  </components:PageLayout>
</ContentPage>
