<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GT4.UI.Pages.ProjectListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GT4.UI.Components"
    xmlns:items="clr-namespace:GT4.UI.Items"
    xmlns:resources="clr-namespace:GT4.UI.Resources;assembly=GT4.UI.Resources"
    x:Name="Root"
    Title="{x:Static resources:UIStrings.TitleProjectPage}">

  <ContentPage.ToolbarItems>
    <ToolbarItem
        Command="{Binding PageCommand, Source={x:Reference Root}}"
        CommandParameter="Create"
        Order="Primary"
        Text="{x:Static resources:UIStrings.MenuItemNameCreateGenealogyTree}" />
    <ToolbarItem
        Command="{Binding PageCommand, Source={x:Reference Root}}"
        CommandParameter="Refresh"
        Order="Secondary"
        Text="{x:Static resources:UIStrings.MenuItemNameRefresh}" />
    <ToolbarItem
        Command="{Binding PageCommand, Source={x:Reference Root}}"
        CommandParameter="Settings"
        Order="Secondary"
        Text="{x:Static resources:UIStrings.MenuItemNameSettings}" />
  </ContentPage.ToolbarItems>

  <components:PageLayout>

    <components:PageLayout.Body>
      <CollectionView
          ItemsSource="{Binding Projects, Source={x:Reference Root}}"
          SelectionChanged="OnProjectSelected"
          SelectionMode="Single">

        <CollectionView.ItemsLayout>
          <LinearItemsLayout
              ItemSpacing="8"
              Orientation="Vertical" />
        </CollectionView.ItemsLayout>

        <CollectionView.ItemTemplate>
          <DataTemplate x:DataType="items:ProjectItem">

            <Border Style="{StaticResource HoverItem}">
              <Grid
                  ColumnDefinitions="Auto, *"
                  ColumnSpacing="12"
                  RowDefinitions="Auto, Auto, Auto">

                <Image
                    Grid.Row="0"
                    Grid.RowSpan="3"
                    Grid.Column="0"
                    Margin="0,2,0,0"
                    HeightRequest="40"
                    Source="{Binding Icon}"
                    VerticalOptions="Start"
                    WidthRequest="40" />

                <Label
                    Grid.Row="0"
                    Grid.Column="1"
                    Style="{StaticResource CardTitle}"
                    Text="{Binding Name}" />

                <Label
                    Grid.Row="1"
                    Grid.Column="1"
                    IsVisible="{Binding DescriptionVisible}"
                    Style="{StaticResource CardSubtitle}"
                    Text="{Binding Description}" />

                <Label
                    Grid.Row="2"
                    Grid.Column="1"
                    IsVisible="{Binding RevisionVisible}"
                    Style="{StaticResource CardContent}"
                    Text="{Binding Revision}" />

              </Grid>
            </Border>

          </DataTemplate>
        </CollectionView.ItemTemplate>
      </CollectionView>
    </components:PageLayout.Body>

    <components:PageLayout.Footer>
      <Button
          Command="{Binding PageCommand, Source={x:Reference Root}}"
          CommandParameter="Create"
          HorizontalOptions="Fill"
          Text="{x:Static resources:UIStrings.BtnNameCreateGenealogyTree}" />
    </components:PageLayout.Footer>

  </components:PageLayout>
</ContentPage>
