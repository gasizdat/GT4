<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GT4.UI.Pages.FamilyPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:behaviors="clr-namespace:GT4.UI.Behaviors"
    xmlns:components="clr-namespace:GT4.UI.Components"
    xmlns:dto="clr-namespace:GT4.Core.Project.Dto;assembly=GT4.Core.Project"
    xmlns:resources="clr-namespace:GT4.UI.Resources;assembly=GT4.UI.Resources"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2021/maui/toolkit"
    x:Name="Root"
    Title="{Binding FamilyName.Value, Source={x:Reference Root}}">

  <ContentPage.ToolbarItems>
    <ToolbarItem
        Command="{Binding PageCommand, Source={x:Reference Root}}"
        CommandParameter="RemoveFamily"
        Order="Secondary"
        Text="{Binding RemoveFamilyToolbarItemName, Source={x:Reference Root}}" />
    <ToolbarItem
        Command="{Binding PageCommand, Source={x:Reference Root}}"
        CommandParameter="EditFamily"
        Order="Secondary"
        Text="{Binding EditFamilyToolbarItemName, Source={x:Reference Root}}" />
    <ToolbarItem
        Command="{Binding PageCommand, Source={x:Reference Root}}"
        CommandParameter="CreatePerson"
        Order="Secondary"
        Text="{x:Static resources:UIStrings.MenuItemNameAddPerson}" />
    <ToolbarItem
        Command="{Binding PageCommand, Source={x:Reference Root}}"
        CommandParameter="Refresh"
        Order="Secondary"
        Text="{x:Static resources:UIStrings.MenuItemNameRefresh}" />
  </ContentPage.ToolbarItems>

  <components:PageLayout>

    <components:PageLayout.Header>
      <Grid
          ColumnDefinitions="Auto, *, Auto"
          HorizontalOptions="Fill"
          RowDefinitions="Auto, Auto"
          VerticalOptions="Start">

        <!--  Row 0 - Subtitle + filters toggle  -->
        <Label
            Grid.Column="0"
            Style="{StaticResource PageSubtitle}"
            Text="{x:Static resources:UIStrings.HintFamilyPage}" />

        <Button
            x:Name="ClearFiltersButton"
            Grid.Column="1"
            Command="{Binding PageCommand, Source={x:Reference Root}}"
            CommandParameter="ClearFilters"
            HorizontalOptions="End"
            Style="{StaticResource DeleteAdorner}"
            ToolTipProperties.Text="{x:Static resources:UIStrings.BtnNameClearFilters}"
            VerticalOptions="Center">
          <Button.Behaviors>
            <behaviors:FadeVisibilityBehavior Duration="500" IsVisible="{Binding IsAnyFilterActive, Source={x:Reference Root}}" />
          </Button.Behaviors>
        </Button>

        <Button
            Grid.Column="2"
            Command="{Binding PageCommand, Source={x:Reference Root}}"
            CommandParameter="ToggleFilters"
            HorizontalOptions="End"
            Style="{StaticResource TextAdorner}"
            Text="{Binding ToggleFiltersButtonName, Source={x:Reference Root}}" />

        <!--  Row 1 - Filters panel. Fades via FadeVisibilityBehavior instead of snapping like a
             plain IsVisible binding would.  -->
        <Grid
            x:Name="FiltersPanel"
            Grid.Row="1"
            Grid.ColumnSpan="3"
            HorizontalOptions="Fill">

          <Grid.Behaviors>
            <behaviors:FadeVisibilityBehavior Duration="500" IsVisible="{Binding IsFiltersVisible, Source={x:Reference Root}}" />
          </Grid.Behaviors>

          <components:PersonFilterFieldsView Filter="{Binding Filter, Source={x:Reference Root}}" />
        </Grid>
      </Grid>
    </components:PageLayout.Header>

    <components:PageLayout.Body>
      <ScrollView>
        <FlexLayout
            AlignContent="Start"
            AlignItems="Start"
            BindableLayout.ItemsSource="{Binding Persons, Source={x:Reference Root}}"
            Direction="Row"
            Wrap="Wrap">

          <BindableLayout.ItemTemplate>
            <DataTemplate x:DataType="dto:PersonInfo">
              <components:CardView
                  FlexLayout.Grow="1"
                  MinimumWidthRequest="{Binding Path=PersonItemMinimalWidth, Source={RelativeSource AncestorType={x:Type ContentPage}}}">

                <components:CardView.GestureRecognizers>
                  <TapGestureRecognizer
                      Command="{Binding Path=MemberItemTappedCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}"
                      CommandParameter="{Binding .}" />
                </components:CardView.GestureRecognizers>

                <components:PersonInfoView
                    DatesLabelStyle="{StaticResource FieldValue}"
                    NameFormat="{Binding PersonNamesFormat, Source={x:Reference Root}}"
                    NameLabelStyle="{StaticResource FieldName}"
                    Person="{Binding .}" />
              </components:CardView>
            </DataTemplate>
          </BindableLayout.ItemTemplate>
        </FlexLayout>
      </ScrollView>
    </components:PageLayout.Body>
    <components:PageLayout.Footer>
      <Button
          Command="{Binding PageCommand, Source={x:Reference Root}}"
          CommandParameter="CreatePerson"
          FontSize="{DynamicResource ActionButtonTextSize}"
          HorizontalOptions="Fill"
          Text="{x:Static resources:UIStrings.BtnNameCreateFamilyPerson}" />
    </components:PageLayout.Footer>
  </components:PageLayout>
</ContentPage>