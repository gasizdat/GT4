<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GT4.UI.Pages.ProjectRevisionsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GT4.UI.Components"
    xmlns:items="clr-namespace:GT4.UI.Items"
    xmlns:resources="clr-namespace:GT4.UI.Resources;assembly=GT4.UI.Resources"
    x:Name="Root"
    NavigatedTo="OnNavigatedTo"
    Title="{x:Static resources:UIStrings.TitleProjectRevisionsPage}">

  <ContentPage.ToolbarItems>
    <ToolbarItem
        Command="{Binding PageCommand, Source={x:Reference Root}}"
        CommandParameter="Refresh"
        Order="Secondary"
        Text="{x:Static resources:UIStrings.MenuItemNameRefresh}" />
  </ContentPage.ToolbarItems>

  <components:PageLayout>

    <components:PageLayout.Body>
      <CollectionView
          HorizontalOptions="Fill"
          ItemsSource="{Binding Revisions, Source={x:Reference Root}}"
          SelectedItem="{Binding SelectedRevision, Source={x:Reference Root}}"
          SelectionMode="Single"
          VerticalOptions="Start">

        <CollectionView.ItemsLayout>
          <LinearItemsLayout
              ItemSpacing="4"
              Orientation="Vertical" />
        </CollectionView.ItemsLayout>

        <CollectionView.ItemTemplate>
          <DataTemplate x:DataType="items:ProjectRevisionItem">
            <Grid
                Padding="4,2"
                ColumnDefinitions="*, Auto"
                Style="{StaticResource SelectableItem}">

              <Label
                  Padding="{StaticResource CollectionItemsVerticalPadding}"
                  HorizontalOptions="Fill"
                  Style="{StaticResource FieldValue}"
                  Text="{Binding DateTimeText}" />

              <Button
                  Grid.Column="1"
                  Command="{Binding DeleteRevisionCommand, Source={x:Reference Root}}"
                  CommandParameter="{Binding .}"
                  Style="{StaticResource DeleteAdorner}"
                  VerticalOptions="Center" />

            </Grid>
          </DataTemplate>
        </CollectionView.ItemTemplate>

      </CollectionView>
    </components:PageLayout.Body>

    <components:PageLayout.Footer>
      <Button
          Command="{Binding PageCommand, Source={x:Reference Root}}"
          CommandParameter="Restore"
          HorizontalOptions="Fill"
          Text="{Binding RestoreBtnName, Source={x:Reference Root}}" />
    </components:PageLayout.Footer>

  </components:PageLayout>
</ContentPage>
