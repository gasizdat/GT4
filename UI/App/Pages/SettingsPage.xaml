<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GT4.UI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GT4.UI.Components"
    xmlns:resources="clr-namespace:GT4.UI.Resources;assembly=GT4.UI.Resources"
    x:Name="Root"
    Title="{x:Static resources:UIStrings.TitleSettingsPage}">

  <components:PageLayout>
    <components:PageLayout.Body>
      <Grid RowDefinitions="Auto, *">

        <Border
            Grid.Row="0"
            Margin="{Thickness Bottom={StaticResource PageContentSpacing}}">
          <Grid
              ColumnDefinitions="*, Auto, Auto"
              RowDefinitions="Auto, Auto, Auto, Auto">
            <Label
                Grid.Row="0"
                Grid.ColumnSpan="3"
                Style="{StaticResource GroupTitle}"
                Text="{x:Static resources:UIStrings.FieldFontScale}" />
            <Label
                Grid.Row="1"
                Grid.ColumnSpan="3"
                Style="{StaticResource FieldValue}"
                Text="{x:Static resources:UIStrings.FieldFontScaleHint}" />
            <BoxView
                Grid.Row="2"
                Grid.ColumnSpan="3"
                Style="{StaticResource HorizontalDivider}" />
            <Label
                Grid.Row="3"
                Grid.Column="0"
                Style="{StaticResource FieldValue}"
                Text="{Binding FontScalePercent, Source={x:Reference Root}}"
                VerticalOptions="Center" />
            <Stepper
                Grid.Row="3"
                Grid.Column="1"
                Increment="{Binding FontScaleIncrement, Source={x:Reference Root}}"
                Maximum="{Binding FontScaleMaximum, Source={x:Reference Root}}"
                Minimum="{Binding FontScaleMinimum, Source={x:Reference Root}}"
                VerticalOptions="Center"
                Value="{Binding FontScaleFactor, Source={x:Reference Root}}" />
            <Button
                Grid.Row="3"
                Grid.Column="2"
                Command="{Binding ResetFontScaleCommand, Source={x:Reference Root}}"
                Style="{StaticResource DeleteAdorner}" />
          </Grid>
        </Border>

        <CollectionView
            Grid.Row="1"
            ItemsSource="{Binding SettingEditors, Source={x:Reference Root}}">

          <CollectionView.ItemsLayout>
            <LinearItemsLayout
                ItemSpacing="3"
                Orientation="Vertical" />
          </CollectionView.ItemsLayout>

          <CollectionView.ItemTemplate>
            <DataTemplate>
              <components:SettingEditorView Editor="{Binding .}" />
            </DataTemplate>
          </CollectionView.ItemTemplate>
        </CollectionView>
      </Grid>
    </components:PageLayout.Body>
  </components:PageLayout>

</ContentPage>