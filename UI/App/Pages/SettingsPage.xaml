<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GT4.UI.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GT4.UI.Components"
    xmlns:resources="clr-namespace:GT4.UI.Resources;assembly=GT4.UI.Resources"
    x:Name="Root"
    Title="{x:Static resources:UIStrings.TitleSettingsPage}">

  <ContentPage.Resources>
    <ResourceDictionary>
      <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Margin" Value="{Thickness Bottom={StaticResource PageContentSpacing}}" />
      </Style>
    </ResourceDictionary>
  </ContentPage.Resources>

  <components:PageLayout>
    <components:PageLayout.Body>
      <VerticalStackLayout>
        <!--  Full Dates  -->
        <Border Style="{StaticResource CardBorderStyle}">
          <Grid
              ColumnDefinitions="*"
              RowDefinitions="Auto, Auto, Auto, Auto, Auto">
            <Label
                Grid.Row="0"
                Style="{StaticResource GroupTitle}"
                Text="{x:Static resources:UIStrings.FieldDateDisplayFormat}" />
            <Label
                Grid.Row="1"
                Style="{StaticResource FieldValue}"
                Text="{x:Static resources:UIStrings.FieldDateDisplayFormatHint}" />
            <BoxView
                Grid.Row="2"
                Style="{StaticResource HorizontalDivider}" />
            <Label
                Grid.Row="3"
                Style="{StaticResource FieldValue}"
                Text="{Binding DateExample, Source={x:Reference Root}}" />
            <Entry
                Grid.Row="4"
                Text="{Binding DateFormat, Source={x:Reference Root}}" />
          </Grid>
        </Border>

        <!--  Short Dates  -->
        <Border Style="{StaticResource CardBorderStyle}">
          <Grid
              ColumnDefinitions="*"
              RowDefinitions="Auto, Auto, Auto, Auto, Auto">
            <Label
                Grid.Row="0"
                Style="{StaticResource GroupTitle}"
                Text="{x:Static resources:UIStrings.FieldShortDateDisplayFormat}" />
            <Label
                Grid.Row="1"
                Style="{StaticResource FieldValue}"
                Text="{x:Static resources:UIStrings.FieldShortDateDisplayFormatHint}" />
            <BoxView
                Grid.Row="2"
                Style="{StaticResource HorizontalDivider}" />
            <Label
                Grid.Row="3"
                Style="{StaticResource FieldValue}"
                Text="{Binding ShortDateExample, Source={x:Reference Root}}" />
            <Entry
                Grid.Row="4"
                Text="{Binding ShortDateFormat, Source={x:Reference Root}}" />
          </Grid>
        </Border>
      </VerticalStackLayout>
    </components:PageLayout.Body>
  </components:PageLayout>

</ContentPage>