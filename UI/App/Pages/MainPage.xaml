<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GT4.UI.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GT4.UI.Components"
    xmlns:pages="clr-namespace:GT4.UI.Pages"
    xmlns:resources="clr-namespace:GT4.UI.Resources;assembly=GT4.UI.Resources"
    xmlns:utils="clr-namespace:GT4.UI.Utils;assembly=GT4.UI.Utils"
    x:Name="Root"
    x:DataType="pages:MainPage">

  <components:PageLayout>
    <components:PageLayout.Header>
      <HorizontalStackLayout
          HorizontalOptions="End"
          Spacing="{StaticResource PageContentSpacing}">
        <Picker
            Title="{x:Static resources:UIStrings.PkrLanguageHint}"
            ItemDisplayBinding="{Binding Name, x:DataType=utils:Language}"
            ItemsSource="{Binding Languages, Source={x:Reference Root}}"
            SelectedItem="{Binding SelectedLanguage, Source={x:Reference Root}}" />
        <Button
            x:Name="SettingsBtn"
            Command="{Binding PageCommand, Source={x:Reference Root}}"
            CommandParameter="OpenSettings"
            FontSize="Large"
            Style="{StaticResource EmojiAdorner}"
            Text="⚙️"
            VerticalOptions="Fill"
            WidthRequest="{Binding Source={x:Reference SettingsBtn}, Path=Height, x:DataType=Button}" />
      </HorizontalStackLayout>
    </components:PageLayout.Header>

    <components:PageLayout.Body>
      <VerticalStackLayout Spacing="{x:StaticResource PageContentSpacing}">

        <!--Image
            Aspect="AspectFit"
            HeightRequest="200"
            Source="gt4_logo.png" /-->

        <Label
            HorizontalOptions="Fill"
            HorizontalTextAlignment="Center"
            Style="{StaticResource PageTitle}"
            Text="{x:Static resources:UIStrings.AppGeneralName}" />

        <Label
            HorizontalOptions="Fill"
            HorizontalTextAlignment="Center"
            Style="{StaticResource PageSubtitle}"
            Text="{x:Static resources:UIStrings.AppGeneralWelcomeTitle}" />

        <Label
            HorizontalOptions="Fill"
            HorizontalTextAlignment="Center"
            Style="{StaticResource FieldValue}"
            Text="{Binding AppVersion, Source={x:Reference Root}}" />

        <!--  TODO: Temporary code for testing — to be removed before production.  -->
        <VerticalStackLayout IsVisible="Hidden">
          <Button
              HeightRequest="20"
              Style="{StaticResource DeleteAdorner}"
              WidthRequest="20" />
          <Label
              Style="{StaticResource PageTitle}"
              Text="PageTitle" />
          <Label
              Style="{StaticResource PageSubtitle}"
              Text="PageSubtitle" />
          <Label
              Style="{StaticResource GroupTitle}"
              Text="GroupTitle" />
          <Label
              Style="{StaticResource GroupSubtitle}"
              Text="GroupSubtitle" />
          <Label
              Style="{StaticResource CardTitle}"
              Text="CardTitle" />
          <Label
              Style="{StaticResource CardSubtitle}"
              Text="CardSubtitle" />
          <Label
              Style="{StaticResource CardContent}"
              Text="CardContent" />
          <Label
              Style="{StaticResource FieldName}"
              Text="FieldName" />
          <Label
              Style="{StaticResource FieldValue}"
              Text="FieldValue" />

        </VerticalStackLayout>

      </VerticalStackLayout>
    </components:PageLayout.Body>

    <components:PageLayout.Footer>
      <Button
          Command="{Binding PageCommand, Source={x:Reference Root}}"
          CommandParameter="OpenOrCreateDialog"
          FontSize="Large"
          HorizontalOptions="Fill"
          Text="{x:Static resources:UIStrings.BtnNameOpenOrCreateProject}" />
    </components:PageLayout.Footer>

  </components:PageLayout>
</ContentPage>
