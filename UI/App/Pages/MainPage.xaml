<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GT4.UI.Pages.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GT4.UI.Components"
    xmlns:resources="clr-namespace:GT4.UI.Resources;assembly=GT4.UI.Resources"
    x:Name="Root">

  <components:PageLayout>
    <components:PageLayout.Header>
      <HorizontalStackLayout
          HorizontalOptions="End"
          Spacing="{StaticResource PageContentSpacing}">
        <Picker
            Title="{x:Static resources:UIStrings.PkrLanguageHint}"
            ItemDisplayBinding="{Binding Name}"
            ItemsSource="{Binding Languages, Source={x:Reference Root}}"
            SelectedItem="{Binding SelectedLanguage, Source={x:Reference Root}}" />
        <Button
            x:Name="SettingsBtn"
            Command="{Binding PageCommand, Source={x:Reference Root}}"
            CommandParameter="OpenSettings"
            FontSize="{DynamicResource ActionButtonTextSize}"
            Style="{StaticResource EmojiAdorner}"
            Text="⚙️"
            VerticalOptions="Fill"
            WidthRequest="{Binding Source={x:Reference SettingsBtn}, Path=Height}" />
      </HorizontalStackLayout>
    </components:PageLayout.Header>

    <components:PageLayout.Body>
      <VerticalStackLayout Spacing="{x:StaticResource PageContentSpacing}">

        <!--Image
            Aspect="AspectFit"
            HeightRequest="200"
            Source="gt4_logo.png" /-->

        <Label
            HorizontalOptions="Fill"
            HorizontalTextAlignment="Center"
            Style="{StaticResource PageTitle}"
            Text="{x:Static resources:UIStrings.AppGeneralName}" />

        <Label
            HorizontalOptions="Fill"
            HorizontalTextAlignment="Center"
            Style="{StaticResource PageSubtitle}"
            Text="{x:Static resources:UIStrings.AppGeneralWelcomeTitle}" />

        <Label
            HorizontalOptions="Fill"
            HorizontalTextAlignment="Center"
            Style="{StaticResource FieldValue}"
            Text="{Binding AppVersion, Source={x:Reference Root}}" />

      </VerticalStackLayout>
    </components:PageLayout.Body>

    <components:PageLayout.Footer>
      <Button
          Command="{Binding PageCommand, Source={x:Reference Root}}"
          CommandParameter="OpenOrCreateDialog"
          FontSize="{DynamicResource ActionButtonTextSize}"
          HorizontalOptions="Fill"
          Text="{x:Static resources:UIStrings.BtnNameOpenOrCreateProject}" />
    </components:PageLayout.Footer>

  </components:PageLayout>
</ContentPage>
