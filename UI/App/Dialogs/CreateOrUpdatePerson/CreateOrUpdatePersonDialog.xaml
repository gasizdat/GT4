<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GT4.UI.Dialogs.CreateOrUpdatePersonDialog"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GT4.UI.Components"
    xmlns:dto="clr-namespace:GT4.Core.Project.Dto;assembly=GT4.Core.Project"
    xmlns:resources="clr-namespace:GT4.UI.Resources;assembly=GT4.UI.Resources"
    x:Name="Root">

  <ContentPage.Resources>
    <ResourceDictionary>

      <OnIdiom
          x:Key="PhotoHeight"
          x:TypeArguments="x:Double"
          Desktop="300"
          Phone="100"
          Tablet="140" />

      <OnIdiom
          x:Key="PhotoWidth"
          x:TypeArguments="x:Double"
          Desktop="300"
          Phone="100"
          Tablet="140" />

      <OnIdiom
          x:Key="MinBioHeight"
          x:TypeArguments="x:Double"
          Desktop="300"
          Phone="100"
          Tablet="140" />

      <Style x:Key="PhotoPreviewStyle" TargetType="Image">
        <Setter Property="Aspect" Value="AspectFit" />
        <Setter Property="HeightRequest" Value="{StaticResource PhotoHeight}" />
        <Setter Property="WidthRequest" Value="{StaticResource PhotoWidth}" />
        <Setter Property="HorizontalOptions" Value="Center" />
        <Setter Property="VerticalOptions" Value="Center" />
      </Style>

      <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Margin" Value="{Thickness Bottom={StaticResource PageContentSpacing}}" />
      </Style>

    </ResourceDictionary>
  </ContentPage.Resources>

  <components:PageLayout>
    <components:PageLayout.Header>
      <Label
          Style="{StaticResource PageTitle}"
          Text="{x:Static resources:UIStrings.TitleCreateOrUpdatePersonDialog}" />
    </components:PageLayout.Header>

    <components:PageLayout.Body>
      <ScrollView>
        <VerticalStackLayout>

          <!--  Pictures  -->
          <Border Style="{StaticResource CardBorderStyle}">
            <Grid
                ColumnDefinitions="*, Auto, Auto"
                RowDefinitions="Auto, Auto">
              <Label
                  Grid.Row="0"
                  Grid.Column="0"
                  Grid.ColumnSpan="3"
                  Style="{StaticResource GroupTitle}"
                  Text="{x:Static resources:UIStrings.FieldPersonPhotos}" />
              <CollectionView
                  Grid.Row="1"
                  Grid.Column="0"
                  HorizontalScrollBarVisibility="Always"
                  ItemsSource="{Binding Photos, Source={x:Reference Root}}"
                  SelectionMode="Single">

                <CollectionView.ItemsLayout>
                  <LinearItemsLayout Orientation="Horizontal" />
                </CollectionView.ItemsLayout>

                <CollectionView.ItemTemplate>
                  <DataTemplate>
                    <Grid
                        x:Name="PersonPhoto"
                        ColumnDefinitions="*, Auto, Auto"
                        RowDefinitions="Auto, Auto, *"
                        Style="{StaticResource HoverItem}">

                      <Image
                          Grid.Row="0"
                          Grid.RowSpan="3"
                          Grid.Column="0"
                          Grid.ColumnSpan="3"
                          Source="{Binding Content}"
                          Style="{StaticResource PhotoPreviewStyle}" />

                      <Button
                          Grid.Row="0"
                          Grid.Column="1"
                          Command="{Binding DialogCommand, Source={x:Reference Root}}"
                          Style="{StaticResource EditAdorner}">

                        <Button.CommandParameter>
                          <components:AdornerCommandParameter
                              CommandName="EditPhotoCommand"
                              Element="{Binding Source={x:Reference PersonPhoto}, Path=BindingContext}" />
                        </Button.CommandParameter>
                      </Button>

                      <Button
                          Grid.Row="0"
                          Grid.Column="2"
                          Command="{Binding DialogCommand, Source={x:Reference Root}}"
                          Style="{StaticResource DeleteAdorner}">

                        <Button.CommandParameter>
                          <components:AdornerCommandParameter
                              CommandName="RemovePhotoCommand"
                              Element="{Binding Source={x:Reference PersonPhoto}, Path=BindingContext}" />
                        </Button.CommandParameter>
                      </Button>

                      <Button
                          Grid.Row="1"
                          Grid.Column="1"
                          Command="{Binding DialogCommand, Source={x:Reference Root}}"
                          Style="{StaticResource LeftAdorner}">

                        <Button.CommandParameter>
                          <components:AdornerCommandParameter
                              CommandName="MovePhotoToLeftCommand"
                              Element="{Binding Source={x:Reference PersonPhoto}, Path=BindingContext}" />
                        </Button.CommandParameter>
                      </Button>

                      <Button
                          Grid.Row="1"
                          Grid.Column="2"
                          Command="{Binding DialogCommand, Source={x:Reference Root}}"
                          Style="{StaticResource RightAdorner}">

                        <Button.CommandParameter>
                          <components:AdornerCommandParameter
                              CommandName="MovePhotoToRightCommand"
                              Element="{Binding Source={x:Reference PersonPhoto}, Path=BindingContext}" />
                        </Button.CommandParameter>
                      </Button>

                    </Grid>
                  </DataTemplate>
                </CollectionView.ItemTemplate>
              </CollectionView>
              <Button
                  Grid.Row="1"
                  Grid.Column="1"
                  Command="{Binding DialogCommand, Source={x:Reference Root}}"
                  CommandParameter="AddPhotoCommand"
                  HeightRequest="{StaticResource PhotoHeight}"
                  Style="{StaticResource AddAdorner}" />

            </Grid>
          </Border>

          <!--  Attachments  -->
          <Border Style="{StaticResource CardBorderStyle}">
            <Grid
                ColumnDefinitions="*, Auto"
                RowDefinitions="Auto, *, Auto">

              <Label
                  Grid.Row="0"
                  Grid.Column="0"
                  Grid.ColumnSpan="2"
                  Style="{StaticResource GroupTitle}"
                  Text="{x:Static resources:UIStrings.FieldPersonAttachments}" />

              <CollectionView
                  Grid.Row="1"
                  Grid.Column="0"
                  Grid.ColumnSpan="2"
                  ItemsSource="{Binding Attachments, Source={x:Reference Root}}"
                  SelectionMode="Single">

                <CollectionView.ItemTemplate>
                  <DataTemplate>
                    <Grid
                        x:Name="PersonAttachment"
                        Padding="{StaticResource CollectionItemsVerticalPadding}"
                        ColumnDefinitions="*, Auto, Auto, Auto, Auto"
                        Style="{StaticResource HoverItem}">

                      <Label
                          Grid.Column="0"
                          Style="{StaticResource FieldValue}"
                          Text="{Binding Content}"
                          VerticalOptions="Center" />

                      <Button
                          Grid.Column="1"
                          Command="{Binding DialogCommand, Source={x:Reference Root}}"
                          Style="{StaticResource UpAdorner}"
                          VerticalOptions="Center">

                        <Button.CommandParameter>
                          <components:AdornerCommandParameter
                              CommandName="MoveAttachmentUpCommand"
                              Element="{Binding Source={x:Reference PersonAttachment}, Path=BindingContext}" />
                        </Button.CommandParameter>
                      </Button>

                      <Button
                          Grid.Column="2"
                          Command="{Binding DialogCommand, Source={x:Reference Root}}"
                          Style="{StaticResource DownAdorner}"
                          VerticalOptions="Center">

                        <Button.CommandParameter>
                          <components:AdornerCommandParameter
                              CommandName="MoveAttachmentDownCommand"
                              Element="{Binding Source={x:Reference PersonAttachment}, Path=BindingContext}" />
                        </Button.CommandParameter>
                      </Button>

                      <Button
                          Grid.Column="3"
                          Command="{Binding DialogCommand, Source={x:Reference Root}}"
                          Style="{StaticResource EditAdorner}"
                          VerticalOptions="Center">

                        <Button.CommandParameter>
                          <components:AdornerCommandParameter
                              CommandName="EditAttachmentCommand"
                              Element="{Binding Source={x:Reference PersonAttachment}, Path=BindingContext}" />
                        </Button.CommandParameter>
                      </Button>

                      <Button
                          Grid.Column="4"
                          Command="{Binding DialogCommand, Source={x:Reference Root}}"
                          Style="{StaticResource DeleteAdorner}"
                          VerticalOptions="Center">

                        <Button.CommandParameter>
                          <components:AdornerCommandParameter
                              CommandName="RemoveAttachmentCommand"
                              Element="{Binding Source={x:Reference PersonAttachment}, Path=BindingContext}" />
                        </Button.CommandParameter>
                      </Button>

                    </Grid>
                  </DataTemplate>
                </CollectionView.ItemTemplate>
              </CollectionView>

              <Button
                  Grid.Row="2"
                  Grid.Column="0"
                  Grid.ColumnSpan="2"
                  Command="{Binding DialogCommand, Source={x:Reference Root}}"
                  CommandParameter="AddAttachmentCommand"
                  HorizontalOptions="Fill"
                  Style="{StaticResource TextAdorner}"
                  Text="{x:Static resources:UIStrings.BtnNameAddPersonAttachment}" />
            </Grid>
          </Border>

          <!--  Biological Sex  -->
          <Border Style="{StaticResource CardBorderStyle}">
            <Grid
                ColumnDefinitions="Auto, *"
                RowDefinitions="Auto">

              <Label
                  Grid.Row="0"
                  Grid.Column="0"
                  Style="{StaticResource FieldName}"
                  Text="{x:Static resources:UIStrings.FieldBiologicalSex}" />

              <Picker
                  Grid.Row="0"
                  Grid.Column="1"
                  ItemDisplayBinding="{Binding Name}"
                  ItemsSource="{Binding BiologicalSexes, Source={x:Reference Root}}"
                  SelectedItem="{Binding BioSex, Source={x:Reference Root}}"
                  Style="{StaticResource FieldValue}" />

            </Grid>
          </Border>

          <!--  Names  -->
          <Border Style="{StaticResource CardBorderStyle}">
            <Grid
                ColumnDefinitions="Auto, *"
                RowDefinitions="Auto, *, Auto">

              <Label
                  Grid.Row="0"
                  Grid.Column="0"
                  Style="{StaticResource GroupTitle}"
                  Text="{x:Static resources:UIStrings.FieldPersonNames}" />

              <Label
                  Grid.Row="0"
                  Grid.Column="1"
                  Margin="{Thickness Bottom={StaticResource GroupTitleMarginBottom},
                                     Left={StaticResource PageContentSpacing}}"
                  Style="{StaticResource FieldValue}"
                  Text="{Binding PersonFullName, Source={x:Reference Root}}" />

              <CollectionView
                  Grid.Row="1"
                  Grid.Column="0"
                  Grid.ColumnSpan="2"
                  HorizontalOptions="Center"
                  ItemsSource="{Binding Names, Source={x:Reference Root}}"
                  SelectionMode="Single">

                <CollectionView.ItemTemplate>
                  <DataTemplate>
                    <Grid
                        x:Name="PersonName"
                        Padding="{StaticResource CollectionItemsVerticalPadding}"
                        ColumnDefinitions="*, Auto, Auto, Auto, Auto"
                        RowDefinitions="Auto, Auto"
                        Style="{StaticResource HoverItem}">

                      <Label
                          Grid.Row="0"
                          Grid.Column="0"
                          HorizontalOptions="Start"
                          Style="{StaticResource FieldName}"
                          Text="{Binding Type}" />

                      <Button
                          Grid.Row="0"
                          Grid.RowSpan="2"
                          Grid.Column="1"
                          Command="{Binding DialogCommand, Source={x:Reference Root}}"
                          Style="{StaticResource UpAdorner}"
                          VerticalOptions="Center">

                        <Button.CommandParameter>
                          <components:AdornerCommandParameter
                              CommandName="MoveNameUpCommand"
                              Element="{Binding Source={x:Reference PersonName}, Path=BindingContext}" />
                        </Button.CommandParameter>
                      </Button>

                      <Button
                          Grid.Row="0"
                          Grid.RowSpan="2"
                          Grid.Column="2"
                          Command="{Binding DialogCommand, Source={x:Reference Root}}"
                          Style="{StaticResource DownAdorner}"
                          VerticalOptions="Center">

                        <Button.CommandParameter>
                          <components:AdornerCommandParameter
                              CommandName="MoveNameDownCommand"
                              Element="{Binding Source={x:Reference PersonName}, Path=BindingContext}" />
                        </Button.CommandParameter>
                      </Button>

                      <Button
                          Grid.Row="0"
                          Grid.RowSpan="2"
                          Grid.Column="3"
                          Command="{Binding DialogCommand, Source={x:Reference Root}}"
                          Style="{StaticResource EditAdorner}"
                          VerticalOptions="Center">

                        <Button.CommandParameter>
                          <components:AdornerCommandParameter
                              CommandName="EditNameCommand"
                              Element="{Binding Source={x:Reference PersonName}, Path=BindingContext}" />
                        </Button.CommandParameter>
                      </Button>

                      <Button
                          Grid.Row="0"
                          Grid.RowSpan="2"
                          Grid.Column="4"
                          Command="{Binding DialogCommand, Source={x:Reference Root}}"
                          IsVisible="{Binding CanBeRemoved}"
                          Style="{StaticResource DeleteAdorner}"
                          VerticalOptions="Center">

                        <Button.CommandParameter>
                          <components:AdornerCommandParameter
                              CommandName="RemoveNameCommand"
                              Element="{Binding Source={x:Reference PersonName}, Path=BindingContext}" />
                        </Button.CommandParameter>
                      </Button>

                      <Label
                          Grid.Row="1"
                          Grid.Column="0"
                          Grid.ColumnSpan="5"
                          HorizontalOptions="Fill"
                          Style="{StaticResource FieldValue}"
                          Text="{Binding Value}" />

                    </Grid>
                  </DataTemplate>
                </CollectionView.ItemTemplate>
              </CollectionView>

              <Button
                  Grid.Row="2"
                  Grid.Column="0"
                  Grid.ColumnSpan="2"
                  Command="{Binding DialogCommand, Source={x:Reference Root}}"
                  CommandParameter="AddNameCommand"
                  HorizontalOptions="Fill"
                  Style="{StaticResource TextAdorner}"
                  Text="{x:Static resources:UIStrings.BtnNameAddPersonName}" />
            </Grid>
          </Border>

          <!--  Dates  -->
          <Border Style="{StaticResource CardBorderStyle}">
            <Grid
                ColumnDefinitions="*, Auto, Auto, Auto"
                RowDefinitions="Auto, Auto, Auto">

              <Label
                  Grid.Row="0"
                  Grid.Column="0"
                  Style="{StaticResource GroupTitle}"
                  Text="{x:Static resources:UIStrings.FieldPersonDates}" />

              <components:DateInfoView
                  Grid.Row="1"
                  Grid.Column="0"
                  Caption="{x:Static resources:UIStrings.FieldDateOfBirth}"
                  Date="{Binding BirthDate, Source={x:Reference Root}}" />

              <Button
                  Grid.Row="1"
                  Grid.Column="1"
                  Command="{Binding DialogCommand, Source={x:Reference Root}}"
                  CommandParameter="EditBirthDateCommand"
                  Style="{StaticResource EditAdorner}" />

              <Button
                  Grid.Row="1"
                  Grid.Column="2"
                  Command="{Binding DialogCommand, Source={x:Reference Root}}"
                  CommandParameter="UndefinedBirthDateCommand"
                  Style="{StaticResource EmojiAdorner}"
                  Text="�" />

              <components:DateInfoView
                  Grid.Row="2"
                  Grid.Column="0"
                  Caption="{x:Static resources:UIStrings.FieldDateOfDeath}"
                  Date="{Binding DeathDate, Source={x:Reference Root}}" />

              <Button
                  Grid.Row="2"
                  Grid.Column="1"
                  Command="{Binding DialogCommand, Source={x:Reference Root}}"
                  CommandParameter="EditDeathDateCommand"
                  Style="{StaticResource EditAdorner}" />

              <Button
                  Grid.Row="2"
                  Grid.Column="2"
                  Command="{Binding DialogCommand, Source={x:Reference Root}}"
                  CommandParameter="UndefinedDeathDateCommand"
                  Style="{StaticResource EmojiAdorner}"
                  Text="�" />

              <Button
                  Grid.Row="2"
                  Grid.Column="3"
                  Command="{Binding DialogCommand, Source={x:Reference Root}}"
                  CommandParameter="RemoveDeathDateCommand"
                  Style="{StaticResource DeleteAdorner}" />

            </Grid>
          </Border>

          <!--  Relationships  -->
          <Border Style="{StaticResource CardBorderStyle}">
            <Grid
                ColumnDefinitions="*"
                RowDefinitions="Auto, *, Auto">

              <Label
                  Grid.Row="0"
                  Grid.Column="0"
                  Style="{StaticResource GroupTitle}"
                  Text="{x:Static resources:UIStrings.FieldPersonRelationships}" />

              <CollectionView
                  Grid.Row="1"
                  Grid.Column="0"
                  ItemsSource="{Binding Relatives, Source={x:Reference Root}}"
                  SelectionMode="Single">

                <CollectionView.ItemTemplate>
                  <DataTemplate x:DataType="dto:RelativeInfo">
                    <Grid
                        x:Name="PersonRelative"
                        Padding="{StaticResource CollectionItemsVerticalPadding}"
                        ColumnDefinitions="*, Auto, Auto"
                        RowDefinitions="Auto"
                        Style="{StaticResource HoverItem}">

                      <components:RelativeInfoView
                          Grid.Row="0"
                          Grid.Column="0"
                          Relative="{Binding .}" />

                      <Button
                          Grid.Row="0"
                          Grid.Column="1"
                          Command="{Binding DialogCommand, Source={x:Reference Root}}"
                          Style="{StaticResource EditAdorner}"
                          VerticalOptions="Center">

                        <Button.CommandParameter>
                          <components:AdornerCommandParameter
                              CommandName="EditRelativeCommand"
                              Element="{Binding Source={x:Reference PersonRelative}, Path=BindingContext}" />
                        </Button.CommandParameter>
                      </Button>

                      <Button
                          Grid.Row="0"
                          Grid.Column="2"
                          Command="{Binding DialogCommand, Source={x:Reference Root}}"
                          Style="{StaticResource DeleteAdorner}"
                          VerticalOptions="Center">

                        <Button.CommandParameter>
                          <components:AdornerCommandParameter
                              CommandName="RemoveRelativeCommand"
                              Element="{Binding Source={x:Reference PersonRelative}, Path=BindingContext}" />
                        </Button.CommandParameter>
                      </Button>

                    </Grid>
                  </DataTemplate>
                </CollectionView.ItemTemplate>
              </CollectionView>

              <Button
                  Grid.Row="2"
                  Grid.Column="0"
                  Command="{Binding DialogCommand, Source={x:Reference Root}}"
                  CommandParameter="AddRelationship"
                  HorizontalOptions="Fill"
                  Style="{StaticResource TextAdorner}"
                  Text="{x:Static resources:UIStrings.BtnNameAddPersonRelationship}" />

            </Grid>
          </Border>

          <!--  Biography  -->
          <Border Style="{StaticResource CardBorderStyle}">
            <Grid
                ColumnDefinitions="*"
                RowDefinitions="Auto, *">

              <Label
                  Grid.Row="0"
                  Grid.Column="0"
                  Style="{StaticResource GroupTitle}"
                  Text="{x:Static resources:UIStrings.FieldPersonBiography}" />

              <components:MarkdownEditor
                  x:Name="BiographyEditor"
                  Grid.Row="1"
                  Grid.Column="0"
                  InsertLinkCommand="{Binding DialogCommand, Source={x:Reference Root}}"
                  Markdown="{Binding Biography.Content, Source={x:Reference Root}}"
                  MinimumHeightRequest="{StaticResource MinBioHeight}"
                  Placeholder="{x:Static resources:UIStrings.TxtPlaceholderBiography}" />
            </Grid>
          </Border>

        </VerticalStackLayout>
      </ScrollView>
    </components:PageLayout.Body>

    <components:PageLayout.Footer>
      <Button
          Command="{Binding DialogCommand, Source={x:Reference Root}}"
          CommandParameter="CreatePersonCommand"
          FontSize="{DynamicResource ActionButtonTextSize}"
          Text="{Binding DialogButtonName, Source={x:Reference Root}}" />
    </components:PageLayout.Footer>
  </components:PageLayout>
</ContentPage>