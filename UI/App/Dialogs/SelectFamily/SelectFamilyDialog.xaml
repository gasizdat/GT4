<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GT4.UI.Dialogs.SelectFamilyDialog"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GT4.UI.Components"
    xmlns:resources="clr-namespace:GT4.UI.Resources;assembly=GT4.UI.Resources"
    x:Name="Root">

  <components:PageLayout>
    <components:PageLayout.Header>
      <Label
          Style="{StaticResource PageTitle}"
          Text="{x:Static resources:UIStrings.TitleSelectFamilyDialog}" />
    </components:PageLayout.Header>

    <components:PageLayout.Body>
      <Grid
          Padding="20"
          ColumnDefinitions="Auto, *"
          HorizontalOptions="Fill"
          RowDefinitions="Auto, *, Auto, Auto"
          RowSpacing="10"
          VerticalOptions="Start">

        <Label
            Grid.Row="0"
            Grid.Column="0"
            Style="{StaticResource FieldName}"
            Text="{x:Static resources:UIStrings.FieldSearchText}" />

        <Entry
            Grid.Row="0"
            Grid.Column="1"
            HorizontalOptions="Fill"
            Placeholder="{x:Static resources:UIStrings.HintNameFilterWildcard}"
            Style="{StaticResource FieldValue}"
            Text="{Binding FilterText, Source={x:Reference Root}}" />

        <CollectionView
            x:Name="FamiliesCollectionView"
            Grid.Row="1"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            HorizontalOptions="Fill"
            ItemsSource="{Binding Families, Source={x:Reference Root}}"
            SelectedItem="{Binding CurrentFamily, Source={x:Reference Root}}"
            SelectionMode="Single">
          <CollectionView.ItemTemplate>
            <DataTemplate>
              <Label
                  Padding="{StaticResource CollectionItemsVerticalPadding}"
                  HorizontalOptions="Fill"
                  HorizontalTextAlignment="Start"
                  Style="{StaticResource FieldValue}"
                  Text="{Binding Value}" />
            </DataTemplate>
          </CollectionView.ItemTemplate>
        </CollectionView>

        <Button
            Grid.Row="2"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            Command="{Binding DialogCommand, Source={x:Reference Root}}"
            CommandParameter="AddFamily"
            HorizontalOptions="Fill"
            Style="{StaticResource AddAdorner}" />

        <!--  TODO. Investigate why this placeholder is required so the addorner button doesn't get crop  -->
        <Border
            Grid.Row="3"
            MinimumHeightRequest="{StaticResource AddornerButtonEmojiSize}"
            StrokeThickness="0" />

      </Grid>
    </components:PageLayout.Body>

    <components:PageLayout.Footer>
      <Button
          Command="{Binding DialogCommand, Source={x:Reference Root}}"
          CommandParameter="SelectFamily"
          FontSize="{DynamicResource ActionButtonTextSize}"
          HorizontalOptions="Fill"
          Text="{Binding DialogButtonName, Source={x:Reference Root}}" />
    </components:PageLayout.Footer>
  </components:PageLayout>
</ContentPage>
