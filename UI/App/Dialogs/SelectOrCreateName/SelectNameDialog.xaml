<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GT4.UI.Dialogs.SelectNameDialog"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:behaviors="clr-namespace:GT4.UI.Behaviors"
    xmlns:components="clr-namespace:GT4.UI.Components"
    xmlns:resources="clr-namespace:GT4.UI.Resources;assembly=GT4.UI.Resources"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2021/maui/toolkit"
    x:Name="Root">

  <components:PageLayout>
    <components:PageLayout.Header>
      <VerticalStackLayout Spacing="{StaticResource PageContentSpacing}">

        <Label
            Style="{StaticResource PageTitle}"
            Text="{x:Static resources:UIStrings.TitleSelectNameDialog}" />

        <Grid
            ColumnDefinitions="Auto, *"
            ColumnSpacing="{StaticResource PageContentSpacing}">
          <Label
              Grid.Column="0"
              Style="{StaticResource FieldName}"
              Text="{x:Static resources:UIStrings.FieldSelectName}"
              VerticalOptions="Center" />
          <Picker
              Grid.Column="1"
              ItemDisplayBinding="{Binding TypeName}"
              ItemsSource="{Binding NameTypes, Source={x:Reference Root}}"
              SelectedItem="{Binding CurrentNameType, Source={x:Reference Root}}" />
        </Grid>

      </VerticalStackLayout>
    </components:PageLayout.Header>

    <components:PageLayout.Body>
      <Grid
          RowDefinitions="*, Auto, Auto">

        <CollectionView
            x:Name="NamesCollectionView"
            Grid.Row="0"
            behaviors:ScrollToSelected.ScrollToItem="{Binding CurrentName, Source={x:Reference Root}}"
            HorizontalOptions="Fill"
            ItemsSource="{Binding Names, Source={x:Reference Root}}"
            SelectedItem="{Binding CurrentName, Source={x:Reference Root}}"
            SelectionMode="Single">
          <CollectionView.ItemsLayout>
            <LinearItemsLayout
                ItemSpacing="{StaticResource ItemSpacingSmall}"
                Orientation="Vertical" />
          </CollectionView.ItemsLayout>
          <CollectionView.ItemTemplate>
            <DataTemplate>
              <Grid
                  Padding="{StaticResource ListRowPadding}"
                  ColumnDefinitions="*, Auto"
                  Style="{StaticResource SelectableItem}">
                <Label
                    Padding="{StaticResource CollectionItemsVerticalPadding}"
                    HorizontalOptions="Fill"
                    HorizontalTextAlignment="Start"
                    Style="{StaticResource FieldValue}"
                    Text="{Binding Info.Value}" />
                <Button
                    Grid.Column="1"
                    Command="{Binding DialogCommand, Source={x:Reference Root}}"
                    CommandParameter="{Binding Info}"
                    Style="{StaticResource EditAdorner}"
                    VerticalOptions="Center" />
              </Grid>
            </DataTemplate>
          </CollectionView.ItemTemplate>
        </CollectionView>

        <Button
            Grid.Row="1"
            Command="{Binding DialogCommand, Source={x:Reference Root}}"
            CommandParameter="AddName"
            HorizontalOptions="Fill"
            Margin="{StaticResource TopSpacingSmall}"
            Style="{StaticResource AddAdorner}" />

        <Border
            Grid.Row="2"
            MinimumHeightRequest="{StaticResource AddornerButtonEmojiSize}"
            StrokeThickness="0" />

      </Grid>
    </components:PageLayout.Body>

    <components:PageLayout.Footer>
      <Button
          Command="{Binding DialogCommand, Source={x:Reference Root}}"
          CommandParameter="SelectName"
          HorizontalOptions="Fill"
          Text="{Binding DialogButtonName, Source={x:Reference Root}}" />
    </components:PageLayout.Footer>
  </components:PageLayout>
</ContentPage>
