<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GT4.UI.Dialogs.SelectDateDialog"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GT4.UI.Components"
    xmlns:resources="clr-namespace:GT4.UI.Resources;assembly=GT4.UI.Resources"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2021/maui/toolkit"
    x:Name="Root">

  <components:PageLayout>
    <components:PageLayout.Header>
      <Label
          Style="{StaticResource PageTitle}"
          Text="{x:Static resources:UIStrings.TitleSelectDateDialog}" />
    </components:PageLayout.Header>

    <components:PageLayout.Body>
      <ScrollView>
        <Border>
          <Grid
              ColumnDefinitions="Auto, *, Auto"
              ColumnSpacing="{x:StaticResource PageContentSpacing}"
              RowDefinitions="Auto, Auto, Auto, Auto, Auto"
              RowSpacing="{x:StaticResource PageContentSpacing}">

            <Label
                Grid.Row="0"
                Grid.Column="1"
                HorizontalOptions="Fill"
                HorizontalTextAlignment="End"
                Style="{StaticResource FieldName}"
                Text="{x:Static resources:UIStrings.DateKnownApproximately}"
                VerticalOptions="Center" />
            <Switch
                Grid.Row="0"
                Grid.Column="2"
                IsToggled="{Binding ApproximateSwitch, Source={x:Reference Root}}"
                VerticalOptions="Center" />

            <Label
                Grid.Row="1"
                Grid.Column="0"
                Style="{StaticResource FieldName}"
                Text="{x:Static resources:UIStrings.FieldYear}"
                VerticalOptions="Center" />
            <Entry
                Grid.Row="1"
                Grid.Column="1"
                HorizontalOptions="Fill"
                Keyboard="Numeric"
                Text="{Binding Year, Source={x:Reference Root}}" />
            <Switch
                Grid.Row="1"
                Grid.Column="2"
                IsToggled="{Binding YearSwitch, Source={x:Reference Root}}"
                VerticalOptions="Center" />

            <Label
                Grid.Row="2"
                Grid.Column="0"
                Style="{StaticResource FieldName}"
                Text="{x:Static resources:UIStrings.FieldMonth}"
                VerticalOptions="Center" />
            <Picker
                Grid.Row="2"
                Grid.Column="1"
                HorizontalOptions="Fill"
                ItemDisplayBinding="{Binding .}"
                ItemsSource="{Binding Months, Source={x:Reference Root}}"
                SelectedItem="{Binding Month, Source={x:Reference Root}}" />
            <Switch
                Grid.Row="2"
                Grid.Column="2"
                IsToggled="{Binding MonthSwitch, Source={x:Reference Root}}"
                VerticalOptions="Center" />

            <Label
                Grid.Row="3"
                Grid.Column="0"
                Style="{StaticResource FieldName}"
                Text="{x:Static resources:UIStrings.FieldDay}"
                VerticalOptions="Center" />
            <Picker
                Grid.Row="3"
                Grid.Column="1"
                HorizontalOptions="Fill"
                ItemDisplayBinding="{Binding .}"
                ItemsSource="{Binding Days, Source={x:Reference Root}}"
                SelectedItem="{Binding Day, Source={x:Reference Root}}" />
            <Switch
                Grid.Row="3"
                Grid.Column="2"
                IsToggled="{Binding DaySwitch, Source={x:Reference Root}}"
                VerticalOptions="Center" />

            <Label
                Grid.Row="4"
                Grid.Column="0"
                Style="{StaticResource FieldName}"
                Text="{x:Static resources:UIStrings.FieldDateEntered}"
                VerticalOptions="Center" />
            <Label
                Grid.Row="4"
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Style="{StaticResource FieldValue}"
                Text="{Binding DateString, Source={x:Reference Root}}"
                VerticalOptions="Center" />

          </Grid>
        </Border>
      </ScrollView>
    </components:PageLayout.Body>

    <components:PageLayout.Footer>
      <Button
          Clicked="OnSelectDateBtn"
          HorizontalOptions="Fill"
          Text="{Binding DialogButtonName, Source={x:Reference Root}}" />
    </components:PageLayout.Footer>
  </components:PageLayout>
</ContentPage>
