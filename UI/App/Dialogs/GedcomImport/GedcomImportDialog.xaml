<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GT4.UI.Dialogs.GedcomImportDialog"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GT4.UI.Components"
    xmlns:resources="clr-namespace:GT4.UI.Resources;assembly=GT4.UI.Resources"
    x:Name="Root">

  <components:PageLayout>
    <components:PageLayout.Header>
      <Label
          Style="{StaticResource PageTitle}"
          Text="{x:Static resources:UIStrings.TitleGedcomImportDialog}" />
    </components:PageLayout.Header>

    <components:PageLayout.Body>
      <VerticalStackLayout
          Spacing="{StaticResource PageContentSpacing}"
          VerticalOptions="Center">

        <ActivityIndicator
            HorizontalOptions="Center"
            IsRunning="True" />

        <Label
            HorizontalOptions="Center"
            HorizontalTextAlignment="Center"
            Style="{StaticResource CardSubtitle}"
            Text="{Binding ImportingProjectName, Source={x:Reference Root}}" />

        <Label
            HorizontalOptions="Center"
            HorizontalTextAlignment="Center"
            Style="{StaticResource FieldValue}"
            Text="{Binding StatusText, Source={x:Reference Root}}" />

      </VerticalStackLayout>
    </components:PageLayout.Body>

    <components:PageLayout.Footer>
      <Button
          Command="{Binding DialogCommand, Source={x:Reference Root}}"
          FontSize="{DynamicResource ActionButtonTextSize}"
          HorizontalOptions="Fill"
          IsEnabled="{Binding CanCancel, Source={x:Reference Root}}"
          Text="{x:Static resources:UIStrings.BtnNameCancel}" />
    </components:PageLayout.Footer>
  </components:PageLayout>
</ContentPage>
