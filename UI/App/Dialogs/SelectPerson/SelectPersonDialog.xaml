<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="GT4.UI.Dialogs.SelectPersonDialog"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GT4.UI.Components"
    xmlns:dto="clr-namespace:GT4.Core.Project.Dto;assembly=GT4.Core.Project"
    xmlns:resources="clr-namespace:GT4.UI.Resources;assembly=GT4.UI.Resources"
    x:Name="Root">

  <components:PageLayout>
    <components:PageLayout.Header>
      <Grid
          ColumnDefinitions="Auto, *"
          ColumnSpacing="{StaticResource PageContentSpacing}"
          RowDefinitions="Auto, Auto"
          RowSpacing="{StaticResource PageContentSpacing}">

        <!--  Row 0 - Title  -->
        <Label
            Grid.Row="0"
            Grid.Column="0"
            Grid.ColumnSpan="2"
            HorizontalTextAlignment="Center"
            Style="{StaticResource PageTitle}"
            Text="{x:Static resources:UIStrings.TitleSelectPersonDialog}" />

        <!--  Row 1 - Search  -->
        <Label
            Grid.Row="1"
            Grid.Column="0"
            Style="{StaticResource FieldName}"
            Text="{x:Static resources:UIStrings.FieldSearchText}" />

        <Entry
            Grid.Row="1"
            Grid.Column="1"
            HorizontalOptions="Fill"
            Style="{StaticResource FieldValue}"
            Text="{Binding NameFilter, Source={x:Reference Root}}" />
      </Grid>
    </components:PageLayout.Header>

    <components:PageLayout.Body>
      <CollectionView
          HorizontalOptions="Center"
          ItemsSource="{Binding Persons, Source={x:Reference Root}}"
          SelectedItem="{Binding SelectedPerson, Source={x:Reference Root}}"
          SelectionMode="Single">

        <CollectionView.ItemsLayout>
          <LinearItemsLayout Orientation="Vertical" />
        </CollectionView.ItemsLayout>

        <CollectionView.ItemTemplate>
          <DataTemplate x:DataType="dto:PersonInfo">
            <Grid>
              <components:PersonInfoView
                  DatesLabelStyle="{StaticResource FieldValue}"
                  NameFormat="FullPersonName"
                  NameLabelStyle="{StaticResource FieldName}"
                  Person="{Binding .}" />
            </Grid>
          </DataTemplate>
        </CollectionView.ItemTemplate>
      </CollectionView>
    </components:PageLayout.Body>

    <components:PageLayout.Footer>
      <Button
          Command="{Binding DialogCommand, Source={x:Reference Root}}"
          CommandParameter="SelectPersonCommand"
          FontSize="{DynamicResource ActionButtonTextSize}"
          Text="{Binding DialogButtonName, Source={x:Reference Root}}" />
    </components:PageLayout.Footer>
  </components:PageLayout>
</ContentPage>
