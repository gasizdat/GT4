<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

  <!--  Photo sizes  -->
  <OnIdiom
      x:Key="PhotoThumbHeight"
      x:TypeArguments="x:Double"
      Desktop="64"
      Phone="32"
      Tablet="48" />
  <OnIdiom
      x:Key="PhotoThumbWidth"
      x:TypeArguments="x:Double"
      Desktop="64"
      Phone="32"
      Tablet="48" />
  <OnIdiom
      x:Key="PhotoCompactHeight"
      x:TypeArguments="x:Double"
      Desktop="32"
      Phone="24"
      Tablet="32" />
  <OnIdiom
      x:Key="PhotoCompactWidth"
      x:TypeArguments="x:Double"
      Desktop="32"
      Phone="24"
      Tablet="32" />

  <!--  Typography scale  -->
  <OnIdiom
      x:Key="LabelTextSizeDefault"
      x:TypeArguments="x:Double"
      Desktop="15"
      Phone="14"
      Tablet="14" />
  <OnIdiom
      x:Key="LabelTextSizeMedium"
      x:TypeArguments="x:Double"
      Desktop="17"
      Phone="15"
      Tablet="16" />
  <OnIdiom
      x:Key="LabelTextSizeLarge"
      x:TypeArguments="x:Double"
      Desktop="19"
      Phone="17"
      Tablet="18" />
  <OnIdiom
      x:Key="LabelTextSizeHuge"
      x:TypeArguments="x:Double"
      Desktop="23"
      Phone="21"
      Tablet="22" />
  <OnIdiom
      x:Key="LabelTextSizeGiant"
      x:TypeArguments="x:Double"
      Desktop="28"
      Phone="24"
      Tablet="26" />

  <!--  Layout spacing  -->
  <OnIdiom
      x:Key="PageContentHorizontalPadding"
      x:TypeArguments="x:Double"
      Desktop="32"
      Phone="16"
      Tablet="20" />
  <OnIdiom
      x:Key="PageContentVerticalPadding"
      x:TypeArguments="x:Double"
      Desktop="12"
      Phone="8"
      Tablet="10" />
  <OnIdiom
      x:Key="PageContentSpacing"
      x:TypeArguments="x:Double"
      Desktop="12"
      Phone="8"
      Tablet="10" />

  <!--  Button sizes  -->
  <OnIdiom
      x:Key="ButtonTextSize"
      x:TypeArguments="x:Double"
      Desktop="14"
      Phone="14"
      Tablet="14" />
  <OnIdiom
      x:Key="AdornerButtonTextSize"
      x:TypeArguments="x:Double"
      Desktop="13"
      Phone="11"
      Tablet="12" />
  <OnIdiom
      x:Key="AddornerButtonMarginValues"
      x:TypeArguments="x:Double"
      Desktop="3"
      Phone="2"
      Tablet="2" />
  <OnIdiom
      x:Key="AddornerButtonEmojiSize"
      x:TypeArguments="x:Double"
      Desktop="28"
      Phone="24"
      Tablet="28" />

  <OnIdiom
      x:Key="GroupTitleMarginBottom"
      x:TypeArguments="x:Double"
      Default="16"
      Phone="12" />

  <!--  Thickness tokens  -->
  <Thickness
      x:Key="AddornerButtonMargin"
      Bottom="{StaticResource AddornerButtonMarginValues}"
      Left="{StaticResource AddornerButtonMarginValues}"
      Right="{StaticResource AddornerButtonMarginValues}"
      Top="{StaticResource AddornerButtonMarginValues}" />
  <Thickness
      x:Key="GroupTitleMargin"
      Bottom="{StaticResource GroupTitleMarginBottom}"
      Left="0"
      Right="0"
      Top="0" />
  <Thickness
      x:Key="FieldNameLabelMargin"
      Bottom="0"
      Left="0"
      Right="{StaticResource PageContentSpacing}"
      Top="0" />
  <Thickness
      x:Key="CollectionItemsVerticalPadding"
      Bottom="{StaticResource PageContentVerticalPadding}"
      Left="0"
      Right="0"
      Top="{StaticResource PageContentVerticalPadding}" />

  <!--  Spacing scale  -->
  <OnIdiom
      x:Key="SectionSpacing"
      x:TypeArguments="x:Double"
      Desktop="24"
      Phone="16"
      Tablet="20" />
  <OnIdiom
      x:Key="ItemSpacingSmall"
      x:TypeArguments="x:Double"
      Desktop="4"
      Phone="3"
      Tablet="4" />

  <!--  Component paddings  -->
  <OnIdiom
      x:Key="ButtonPaddingH"
      x:TypeArguments="x:Double"
      Desktop="16"
      Phone="12"
      Tablet="14" />
  <OnIdiom
      x:Key="ButtonPaddingV"
      x:TypeArguments="x:Double"
      Desktop="11"
      Phone="9"
      Tablet="10" />
  <Thickness
      x:Key="ButtonPadding"
      Bottom="{StaticResource ButtonPaddingV}"
      Left="{StaticResource ButtonPaddingH}"
      Right="{StaticResource ButtonPaddingH}"
      Top="{StaticResource ButtonPaddingV}" />

  <OnIdiom
      x:Key="AdornerPaddingH"
      x:TypeArguments="x:Double"
      Desktop="6"
      Phone="4"
      Tablet="5" />
  <OnIdiom
      x:Key="AdornerPaddingV"
      x:TypeArguments="x:Double"
      Desktop="4"
      Phone="2"
      Tablet="3" />
  <Thickness
      x:Key="AdornerPadding"
      Bottom="{StaticResource AdornerPaddingV}"
      Left="{StaticResource AdornerPaddingH}"
      Right="{StaticResource AdornerPaddingH}"
      Top="{StaticResource AdornerPaddingV}" />

  <OnIdiom
      x:Key="CardItemPaddingH"
      x:TypeArguments="x:Double"
      Desktop="10"
      Phone="6"
      Tablet="8" />
  <OnIdiom
      x:Key="CardItemPaddingV"
      x:TypeArguments="x:Double"
      Desktop="8"
      Phone="5"
      Tablet="6" />
  <Thickness
      x:Key="CardItemPadding"
      Bottom="{StaticResource CardItemPaddingV}"
      Left="{StaticResource CardItemPaddingH}"
      Right="{StaticResource CardItemPaddingH}"
      Top="{StaticResource CardItemPaddingV}" />

  <OnIdiom
      x:Key="ListRowPaddingH"
      x:TypeArguments="x:Double"
      Desktop="4"
      Phone="2"
      Tablet="3" />
  <OnIdiom
      x:Key="ListRowPaddingV"
      x:TypeArguments="x:Double"
      Desktop="3"
      Phone="2"
      Tablet="2" />
  <Thickness
      x:Key="ListRowPadding"
      Bottom="{StaticResource ListRowPaddingV}"
      Left="{StaticResource ListRowPaddingH}"
      Right="{StaticResource ListRowPaddingH}"
      Top="{StaticResource ListRowPaddingV}" />

  <!--  Named size tokens  -->
  <OnIdiom
      x:Key="ListIconSize"
      x:TypeArguments="x:Double"
      Desktop="40"
      Phone="28"
      Tablet="34" />
  <OnIdiom
      x:Key="LogoHeight"
      x:TypeArguments="x:Double"
      Desktop="180"
      Phone="120"
      Tablet="150" />

  <!--  Heading and subtitle margins  -->
  <OnIdiom
      x:Key="HeadingMarginTopValue"
      x:TypeArguments="x:Double"
      Desktop="8"
      Phone="4"
      Tablet="6" />
  <OnIdiom
      x:Key="HeadingMarginBottomValue"
      x:TypeArguments="x:Double"
      Desktop="4"
      Phone="2"
      Tablet="3" />
  <Thickness
      x:Key="HeadingMargin"
      Bottom="{StaticResource HeadingMarginBottomValue}"
      Left="0"
      Right="0"
      Top="{StaticResource HeadingMarginTopValue}" />

  <OnIdiom
      x:Key="SubtitleMarginBottomValue"
      x:TypeArguments="x:Double"
      Desktop="8"
      Phone="4"
      Tablet="6" />
  <Thickness
      x:Key="SubtitleMargin"
      Bottom="{StaticResource SubtitleMarginBottomValue}"
      Left="0"
      Right="0"
      Top="0" />

  <Thickness
      x:Key="TopSpacingSmall"
      Bottom="0"
      Left="0"
      Right="0"
      Top="{StaticResource ItemSpacingSmall}" />

  <!--  Controls  -->

  <Style TargetType="ActivityIndicator">
    <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}" />
  </Style>

  <Style TargetType="IndicatorView">
    <Setter Property="IndicatorColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
    <Setter Property="SelectedIndicatorColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}" />
  </Style>

  <!--  Named base — lets CardHoverItem reuse without duplicating setters  -->
  <Style x:Key="CardBase" TargetType="Border">
    <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource DarkDivider}}" />
    <Setter Property="StrokeShape" Value="RoundRectangle 12" />
    <Setter Property="StrokeThickness" Value="1" />
    <Setter Property="Padding" Value="{StaticResource PageContentSpacing}" />
    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceCard}, Dark={StaticResource DarkCard}}" />
  </Style>

  <!--  Implicit Border style — all borders get card appearance by default  -->
  <Style TargetType="Border" BasedOn="{StaticResource CardBase}" />

  <!--  Clickable card with pointer-over highlight  -->
  <Style x:Key="CardHoverItem" TargetType="Border" BasedOn="{StaticResource CardBase}">
    <Setter Property="VisualStateManager.VisualStateGroups">
      <VisualStateGroupList>
        <VisualStateGroup x:Name="CommonStates">
          <VisualState x:Name="Normal">
            <VisualState.Setters>
              <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceCard}, Dark={StaticResource DarkCard}}" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="PointerOver">
            <VisualState.Setters>
              <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PrimaryMuted}, Dark={StaticResource DarkPrimaryMuted}}" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateGroupList>
    </Setter>
  </Style>

  <Style TargetType="BoxView">
    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource DarkDivider}}" />
  </Style>

  <Style x:Key="HorizontalDivider" TargetType="BoxView">
    <Setter Property="HeightRequest" Value="1" />
    <Setter Property="HorizontalOptions" Value="Fill" />
    <Setter Property="Margin" Value="0,10" />
    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource DarkDivider}}" />
  </Style>

  <Style TargetType="Button">
    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource DarkText}}" />
    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}" />
    <Setter Property="FontFamily" Value="OpenSansRegular" />
    <Setter Property="FontSize" Value="{x:StaticResource ButtonTextSize}" />
    <Setter Property="BorderWidth" Value="0" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="{StaticResource ButtonPadding}" />
    <Setter Property="MinimumHeightRequest" Value="44" />
    <Setter Property="MinimumWidthRequest" Value="44" />
    <Setter Property="VisualStateManager.VisualStateGroups">
      <VisualStateGroupList>
        <VisualStateGroup x:Name="CommonStates">
          <VisualState x:Name="Normal" />
          <VisualState x:Name="Disabled">
            <VisualState.Setters>
              <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextDisabled}, Dark={StaticResource DarkTextSecondary}}" />
              <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource DarkSubtle}}" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="PointerOver">
            <VisualState.Setters>
              <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource DarkPrimary}}" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateGroupList>
    </Setter>
  </Style>

  <!--  Adorner base — overlaid action button  -->
  <Style x:Key="ChangeAdorner" TargetType="Button">
    <Setter Property="FontFamily" Value="OpenSansRegular" />
    <Setter Property="FontSize" Value="{x:StaticResource AdornerButtonTextSize}" />
    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource DarkText}}" />
    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}" />
    <Setter Property="BorderWidth" Value="0" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="{StaticResource AdornerPadding}" />
    <Setter Property="Opacity" Value="0.82" />
    <Setter Property="HorizontalOptions" Value="Start" />
    <Setter Property="VerticalOptions" Value="Start" />
    <Setter Property="ZIndex" Value="9999" />
    <Setter Property="Margin" Value="{StaticResource AddornerButtonMargin}" />
    <Setter Property="VisualStateManager.VisualStateGroups">
      <VisualStateGroupList>
        <VisualStateGroup x:Name="CommonStates">
          <VisualState x:Name="Normal" />
          <VisualState x:Name="PointerOver">
            <VisualState.Setters>
              <Setter Property="Opacity" Value="1" />
              <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PrimaryLight}, Dark={StaticResource DarkPrimary}}" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateGroupList>
    </Setter>
  </Style>

  <Style x:Key="TextAdorner" BasedOn="{StaticResource ChangeAdorner}" TargetType="Button">
    <Setter Property="LineBreakMode" Value="WordWrap" />
    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource PrimaryMuted}, Dark={StaticResource DarkPrimaryMuted}}" />
    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style x:Key="EmojiAdorner" BasedOn="{StaticResource ChangeAdorner}" TargetType="Button">
    <Setter Property="LineBreakMode" Value="WordWrap" />
    <Setter Property="MinimumHeightRequest" Value="{StaticResource AddornerButtonEmojiSize}" />
    <Setter Property="MinimumWidthRequest" Value="{StaticResource AddornerButtonEmojiSize}" />
  </Style>

  <Style x:Key="AddAdorner" BasedOn="{StaticResource EmojiAdorner}" TargetType="Button">
    <Setter Property="Text" Value="+" />
    <Setter Property="FontAttributes" Value="Bold" />
    <Setter Property="FontSize" Value="18" />
  </Style>

  <Style x:Key="DeleteAdorner" BasedOn="{StaticResource EmojiAdorner}" TargetType="Button">
    <Setter Property="Text" Value="×" />
    <Setter Property="FontSize" Value="18" />
    <Setter Property="BackgroundColor" Value="#C0443322" />
  </Style>

  <Style x:Key="EditAdorner" BasedOn="{StaticResource EmojiAdorner}" TargetType="Button">
    <Setter Property="Text" Value="✎" />
  </Style>

  <Style x:Key="LeftAdorner" BasedOn="{StaticResource EmojiAdorner}" TargetType="Button">
    <Setter Property="Text" Value="‹" />
    <Setter Property="FontSize" Value="20" />
  </Style>

  <Style x:Key="RightAdorner" BasedOn="{StaticResource EmojiAdorner}" TargetType="Button">
    <Setter Property="Text" Value="›" />
    <Setter Property="FontSize" Value="20" />
  </Style>

  <Style x:Key="UpAdorner" BasedOn="{StaticResource EmojiAdorner}" TargetType="Button">
    <Setter Property="Text" Value="↑" />
  </Style>

  <Style x:Key="DownAdorner" BasedOn="{StaticResource EmojiAdorner}" TargetType="Button">
    <Setter Property="Text" Value="↓" />
  </Style>

  <Style TargetType="CheckBox">
    <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}" />
    <Setter Property="MinimumHeightRequest" Value="44" />
    <Setter Property="MinimumWidthRequest" Value="44" />
    <Setter Property="VisualStateManager.VisualStateGroups">
      <VisualStateGroupList>
        <VisualStateGroup x:Name="CommonStates">
          <VisualState x:Name="Normal" />
          <VisualState x:Name="Disabled">
            <VisualState.Setters>
              <Setter Property="Color" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateGroupList>
    </Setter>
  </Style>

  <Style TargetType="DatePicker">
    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkText}}" />
    <Setter Property="BackgroundColor" Value="Transparent" />
    <Setter Property="FontFamily" Value="OpenSansRegular" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="MinimumHeightRequest" Value="44" />
    <Setter Property="MinimumWidthRequest" Value="44" />
    <Setter Property="VisualStateManager.VisualStateGroups">
      <VisualStateGroupList>
        <VisualStateGroup x:Name="CommonStates">
          <VisualState x:Name="Normal" />
          <VisualState x:Name="Disabled">
            <VisualState.Setters>
              <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextDisabled}, Dark={StaticResource DarkTextSecondary}}" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateGroupList>
    </Setter>
  </Style>

  <Style TargetType="Editor">
    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkText}}" />
    <Setter Property="BackgroundColor" Value="Transparent" />
    <Setter Property="FontFamily" Value="OpenSansRegular" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource TextDisabled}, Dark={StaticResource DarkTextSecondary}}" />
    <Setter Property="MinimumHeightRequest" Value="44" />
    <Setter Property="MinimumWidthRequest" Value="44" />
    <Setter Property="VisualStateManager.VisualStateGroups">
      <VisualStateGroupList>
        <VisualStateGroup x:Name="CommonStates">
          <VisualState x:Name="Normal" />
          <VisualState x:Name="Disabled">
            <VisualState.Setters>
              <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextDisabled}, Dark={StaticResource DarkTextSecondary}}" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateGroupList>
    </Setter>
  </Style>

  <Style TargetType="Entry">
    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkText}}" />
    <Setter Property="BackgroundColor" Value="Transparent" />
    <Setter Property="FontFamily" Value="OpenSansRegular" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource TextDisabled}, Dark={StaticResource DarkTextSecondary}}" />
    <Setter Property="MinimumHeightRequest" Value="44" />
    <Setter Property="MinimumWidthRequest" Value="44" />
    <Setter Property="VisualStateManager.VisualStateGroups">
      <VisualStateGroupList>
        <VisualStateGroup x:Name="CommonStates">
          <VisualState x:Name="Normal" />
          <VisualState x:Name="Disabled">
            <VisualState.Setters>
              <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextDisabled}, Dark={StaticResource DarkTextSecondary}}" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateGroupList>
    </Setter>
  </Style>

  <Style TargetType="Frame">
    <Setter Property="HasShadow" Value="False" />
    <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource DarkDivider}}" />
    <Setter Property="CornerRadius" Value="12" />
    <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource SurfaceCard}, Dark={StaticResource DarkCard}}" />
  </Style>

  <Style TargetType="ImageButton">
    <Setter Property="Opacity" Value="1" />
    <Setter Property="BorderColor" Value="Transparent" />
    <Setter Property="BorderWidth" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="MinimumHeightRequest" Value="44" />
    <Setter Property="MinimumWidthRequest" Value="44" />
    <Setter Property="VisualStateManager.VisualStateGroups">
      <VisualStateGroupList>
        <VisualStateGroup x:Name="CommonStates">
          <VisualState x:Name="Normal" />
          <VisualState x:Name="Disabled">
            <VisualState.Setters>
              <Setter Property="Opacity" Value="0.4" />
            </VisualState.Setters>
          </VisualState>
          <VisualState x:Name="PointerOver" />
        </VisualStateGroup>
      </VisualStateGroupList>
    </Setter>
  </Style>

  <Style TargetType="Label">
    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkText}}" />
    <Setter Property="BackgroundColor" Value="Transparent" />
    <Setter Property="FontFamily" Value="OpenSansRegular" />
    <Setter Property="FontSize" Value="Default" />
    <Setter Property="LineBreakMode" Value="WordWrap" />
    <Setter Property="VisualStateManager.VisualStateGroups">
      <VisualStateGroupList>
        <VisualStateGroup x:Name="CommonStates">
          <VisualState x:Name="Normal" />
          <VisualState x:Name="Disabled">
            <VisualState.Setters>
              <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextDisabled}, Dark={StaticResource DarkTextSecondary}}" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateGroupList>
    </Setter>
  </Style>

  <Style TargetType="Span">
    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkText}}" />
  </Style>

  <!--  Typography hierarchy  -->

  <Style x:Key="ContentBase" TargetType="Label">
    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource MidnightBlue}, Dark={StaticResource DarkText}}" />
    <Setter Property="HorizontalOptions" Value="Start" />
    <Setter Property="VerticalOptions" Value="Center" />
    <Setter Property="HorizontalTextAlignment" Value="Start" />
    <Setter Property="VerticalTextAlignment" Value="Center" />
    <Setter Property="LineBreakMode" Value="WordWrap" />
    <Setter Property="Margin" Value="{StaticResource FieldNameLabelMargin}" />
  </Style>

  <Style x:Key="PageTitle" BasedOn="{StaticResource ContentBase}" TargetType="Label">
    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}" />
    <Setter Property="FontSize" Value="{StaticResource LabelTextSizeGiant}" />
    <Setter Property="FontFamily" Value="OpenSansSemibold" />
  </Style>

  <Style x:Key="PageSubtitle" BasedOn="{StaticResource ContentBase}" TargetType="Label">
    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource DarkTextSecondary}}" />
    <Setter Property="FontSize" Value="{StaticResource LabelTextSizeDefault}" />
  </Style>

  <Style x:Key="GroupTitle" BasedOn="{StaticResource ContentBase}" TargetType="Label">
    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}" />
    <Setter Property="FontSize" Value="{StaticResource LabelTextSizeLarge}" />
    <Setter Property="FontFamily" Value="OpenSansSemibold" />
    <Setter Property="Margin" Value="{StaticResource GroupTitleMargin}" />
  </Style>

  <Style x:Key="GroupSubtitle" BasedOn="{StaticResource ContentBase}" TargetType="Label">
    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource DarkTextSecondary}}" />
    <Setter Property="FontSize" Value="{StaticResource LabelTextSizeLarge}" />
  </Style>

  <Style x:Key="CardTitle" BasedOn="{StaticResource ContentBase}" TargetType="Label">
    <Setter Property="FontSize" Value="{StaticResource LabelTextSizeMedium}" />
    <Setter Property="FontFamily" Value="OpenSansSemibold" />
  </Style>

  <Style x:Key="CardSubtitle" BasedOn="{StaticResource ContentBase}" TargetType="Label">
    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource DarkTextSecondary}}" />
    <Setter Property="FontSize" Value="{StaticResource LabelTextSizeMedium}" />
  </Style>

  <Style x:Key="CardContent" BasedOn="{StaticResource ContentBase}" TargetType="Label">
    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource DarkTextSecondary}}" />
    <Setter Property="FontSize" Value="{StaticResource LabelTextSizeDefault}" />
  </Style>

  <Style x:Key="FieldName" BasedOn="{StaticResource ContentBase}" TargetType="Label">
    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource DarkTextSecondary}}" />
    <Setter Property="FontSize" Value="{StaticResource LabelTextSizeDefault}" />
    <Setter Property="FontAttributes" Value="None" />
  </Style>

  <Style x:Key="FieldValue" BasedOn="{StaticResource ContentBase}" TargetType="Label">
    <Setter Property="FontSize" Value="{StaticResource LabelTextSizeDefault}" />
  </Style>

  <Style TargetType="ListView">
    <Setter Property="SeparatorColor" Value="{AppThemeBinding Light={StaticResource Divider}, Dark={StaticResource DarkDivider}}" />
    <Setter Property="RefreshControlColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}" />
  </Style>

  <Style TargetType="Picker">
    <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextPrimary}, Dark={StaticResource DarkText}}" />
    <Setter Property="TitleColor" Value="{AppThemeBinding Light={StaticResource TextSecondary}, Dark={StaticResource DarkTextSecondary}}" />
    <Setter Property="BackgroundColor" Value="Transparent" />
    <Setter Property="FontFamily" Value="OpenSansRegular" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="MinimumHeightRequest" Value="44" />
    <Setter Property="MinimumWidthRequest" Value="44" />
    <Setter Property="VisualStateManager.VisualStateGroups">
      <VisualStateGroupList>
        <VisualStateGroup x:Name="CommonStates">
          <VisualState x:Name="Normal" />
          <VisualState x:Name="Disabled">
            <VisualState.Setters>
              <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextDisabled}, Dark={StaticResource DarkTextSecondary}}" />
              <Setter Property="TitleColor" Value="{AppThemeBinding Light={StaticResource TextDisabled}, Dark={StaticResource DarkTextSecondary}}" />
            </VisualState.Setters>
          </VisualState>
        </VisualStateGroup>
      </VisualStateGroupList>
    </Setter>
  </Style>

  <Style TargetType="ProgressBar">
    <Setter Property="ProgressColor" Value="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource DarkPrimary}}" />
    <Setter Property="VisualStateManager.VisualStateGroups">
      <VisualStateGroupList>
        <VisualStateGroup x:Name="CommonStates">
          <VisualState x:Name="Normal" />
          <VisualState x:Name="Disabled">
            <VisualState.Setters>
              <Setter Property="ProgressColor" Value="{AppThemeBinding Light={StaticResource Gray300}, Dark={StaticResource Gray600}}" />
            </VisualState.Setters>
