<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

  <!--  Note: For Android please see also Platforms\Android\Resources\values\colors.xml  -->

  <!--  Heritage / Genealogy palette  -->
  <Color x:Key="Primary">#3D5A4E</Color>
  <Color x:Key="PrimaryLight">#5A7B6C</Color>
  <Color x:Key="PrimaryMuted">#E8F0EB</Color>

  <Color x:Key="Accent">#8B6F4E</Color>
  <Color x:Key="AccentMuted">#F2EAE0</Color>

  <Color x:Key="Surface">#FAFAF8</Color>
  <Color x:Key="SurfaceCard">#F4F2EE</Color>
  <Color x:Key="SurfaceSubtle">#EAE7E0</Color>
  <Color x:Key="Divider">#E0DDD7</Color>

  <Color x:Key="TextPrimary">#1A1A1A</Color>
  <Color x:Key="TextSecondary">#5A5550</Color>
  <Color x:Key="TextDisabled">#A09C97</Color>

  <!--  Dark mode  -->
  <Color x:Key="DarkSurface">#1E1E1C</Color>
  <Color x:Key="DarkCard">#2A2A27</Color>
  <Color x:Key="DarkSubtle">#353530</Color>
  <Color x:Key="DarkPrimary">#7BA898</Color>
  <Color x:Key="DarkPrimaryMuted">#2A3D35</Color>
  <Color x:Key="DarkAccent">#C4A882</Color>
  <Color x:Key="DarkText">#F0EDEA</Color>
  <Color x:Key="DarkTextSecondary">#A09C97</Color>
  <Color x:Key="DarkDivider">#3A3A37</Color>

  <!--  Legacy aliases — values updated, keys preserved for compatibility  -->
  <Color x:Key="PrimaryDark">#7BA898</Color>
  <Color x:Key="PrimaryDarkText">#F0EDEA</Color>
  <Color x:Key="Secondary">#E8F0EB</Color>
  <Color x:Key="SecondaryDarkText">#7BA898</Color>
  <Color x:Key="Tertiary">#8B6F4E</Color>
  <Color x:Key="PrimaryButtonHover">#5A7B6C</Color>
  <Color x:Key="PrimaryDarkButtonHover">#AA7BA898</Color>

  <Color x:Key="White">#FAFAF8</Color>
  <Color x:Key="Black">#1A1A1A</Color>
  <Color x:Key="Magenta">#3D5A4E</Color>
  <Color x:Key="MidnightBlue">#2A3530</Color>
  <Color x:Key="OffBlack">#1E1E1C</Color>
  <Color x:Key="Translucent100">#00000000</Color>
  <Color x:Key="Translucent80">#33000000</Color>

  <!--  Warm neutral grays  -->
  <Color x:Key="Gray100">#EAE7E0</Color>
  <Color x:Key="Gray200">#D8D4CC</Color>
  <Color x:Key="Gray300">#BDB9B2</Color>
  <Color x:Key="Gray400">#9E9A94</Color>
  <Color x:Key="Gray500">#7A7670</Color>
  <Color x:Key="Gray600">#505048</Color>
  <Color x:Key="Gray900">#252520</Color>
  <Color x:Key="Gray950">#141410</Color>

  <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
  <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}" />
  <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}" />
  <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource Surface}" />
  <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource TextPrimary}" />

  <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}" />
  <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}" />
  <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}" />
  <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}" />
  <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}" />
  <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}" />
  <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}" />
  <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}" />
</ResourceDictionary>
