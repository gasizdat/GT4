<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="GT4.UI.Components.MarkdownView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Root">
  <WebView>

    <WebView.Source>
      <HtmlWebViewSource Html="{Binding HtmlContent, Source={x:Reference Root}}" />
    </WebView.Source>

  </WebView>
</ContentView>
