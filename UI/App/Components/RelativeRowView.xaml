<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="GT4.UI.Components.RelativeRowView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GT4.UI.Components"
    xmlns:dto="clr-namespace:GT4.Core.Project.Dto;assembly=GT4.Core.Project"
    x:Name="Root"
    x:DataType="components:RelativeRow">

  <ContentView.Resources>
    <ResourceDictionary>
      <OnIdiom
          x:Key="MoreBtnSize"
          x:TypeArguments="x:Double"
          Default="40" />
    </ResourceDictionary>
  </ContentView.Resources>

  <Grid x:Name="LayoutRoot">

    <GraphicsView
        x:Name="Connectors"
        InputTransparent="True" />

    <Grid
        x:Name="ContentRoot"
        ColumnDefinitions="*, Auto">

      <components:RelativeInfoView
          x:Name="Info"
          Grid.Column="0"
          NameFormat="CommonPersonName"
          PersonBirthDate="{Binding PersonBirthDate}"
          Relative="{Binding Relative}"
          SelectCommand="{Binding SelectCommand, Source={x:Reference Root}}" />

      <Button
          Grid.Column="1"
          Command="{Binding ToggleCommand}"
          HeightRequest="{StaticResource MoreBtnSize}"
          Style="{StaticResource EmojiAdorner}"
          Text="{Binding MoreBtnName}"
          VerticalOptions="Start"
          WidthRequest="{StaticResource MoreBtnSize}" />

    </Grid>
  </Grid>
</ContentView>
