<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="GT4.UI.Components.PersonFilterView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:behaviors="clr-namespace:GT4.UI.Behaviors"
    xmlns:resources="clr-namespace:GT4.UI.Resources;assembly=GT4.UI.Resources"
    x:Name="Root">

  <Grid
      HorizontalOptions="Fill"
      RowDefinitions="Auto, Auto">

    <!--  Row 0 - Header text + filters toggle  -->
    <Grid
        Grid.Row="0"
        ColumnDefinitions="*, Auto, Auto">
      <Label
          Grid.Column="0"
          Style="{StaticResource PageSubtitle}"
          Text="{Binding HeaderText, Source={x:Reference Root}}" />

      <Button
          x:Name="ClearFiltersButton"
          Grid.Column="1"
          Clicked="OnClearFiltersClicked"
          HorizontalOptions="End"
          Style="{StaticResource DeleteAdorner}"
          ToolTipProperties.Text="{x:Static resources:UIStrings.BtnNameClearFilters}"
          VerticalOptions="Center">
        <Button.Behaviors>
          <behaviors:FadeVisibilityBehavior
              x:Name="ClearButtonFade"
              Duration="500" />
        </Button.Behaviors>
      </Button>

      <Button
          x:Name="ToggleFiltersButton"
          Grid.Column="2"
          Clicked="OnToggleFiltersClicked"
          HorizontalOptions="End"
          Style="{StaticResource TextAdorner}" />
    </Grid>

    <!--
      Row 1 - Filter fields. Fades via FadeVisibilityBehavior instead of snapping like a plain
      IsVisible binding would.
    -->
    <Grid
        x:Name="FiltersPanel"
        Grid.Row="1"
        ColumnDefinitions="Auto, Auto, *"
        HorizontalOptions="Fill"
        RowDefinitions="Auto, Auto, Auto, Auto">

      <Grid.Behaviors>
        <behaviors:FadeVisibilityBehavior
            x:Name="FiltersPanelFade"
            Duration="500" />
      </Grid.Behaviors>

      <!--  Row 0 - Name search  -->
      <Label
          Grid.Row="0"
          Grid.Column="0"
          Style="{StaticResource FieldName}"
          Text="{x:Static resources:UIStrings.FieldSearchText}" />

      <Entry
          x:Name="NameFilterEntry"
          Grid.Row="0"
          Grid.Column="1"
          Grid.ColumnSpan="2"
          HorizontalOptions="Fill"
          Placeholder="{x:Static resources:UIStrings.HintNameFilterWildcard}"
          Style="{StaticResource FieldValue}"
          TextChanged="OnNameFilterChanged" />

      <!--  Row 1 - Sex / marital status  -->
      <Label
          Grid.Row="1"
          Grid.Column="0"
          Style="{StaticResource FieldName}"
          Text="{x:Static resources:UIStrings.FieldFilterSex}" />

      <Picker
          x:Name="SexFilterPicker"
          Grid.Row="1"
          Grid.Column="1"
          SelectedIndexChanged="OnSexFilterChanged"
          Style="{StaticResource FieldValue}" />

      <Picker
          x:Name="MaritalStatusFilterPicker"
          Grid.Row="1"
          Grid.Column="2"
          SelectedIndexChanged="OnMaritalStatusFilterChanged"
          Style="{StaticResource FieldValue}" />

      <!--  Row 2 - Year filter toggle  -->
      <Label
          Grid.Row="2"
          Grid.Column="0"
          Style="{StaticResource FieldName}"
          Text="{x:Static resources:UIStrings.FieldYear}" />

      <Switch
          x:Name="YearFilterSwitch"
          Grid.Row="2"
          Grid.Column="1"
          Toggled="OnYearFilterToggled" />

      <Label
          x:Name="SelectedYearLabel"
          Grid.Row="2"
          Grid.Column="2"
          HorizontalOptions="End"
          Style="{StaticResource FieldValue}" />

      <!--  Row 3 - Year slider  -->
      <Slider
          x:Name="YearSlider"
          Grid.Row="3"
          Grid.ColumnSpan="3"
          IsEnabled="False"
          ValueChanged="OnYearSliderChanged" />
    </Grid>
  </Grid>
</ContentView>
