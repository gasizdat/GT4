<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="GT4.UI.Components.SettingEditorView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Name="Root">

  <ContentView.Resources>
    <ResourceDictionary>
      <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Margin" Value="{Thickness Bottom={StaticResource PageContentSpacing}}" />
      </Style>
    </ResourceDictionary>
  </ContentView.Resources>

  <Border Style="{StaticResource CardBorderStyle}">
    <Grid
        ColumnDefinitions="*, Auto"
        RowDefinitions="Auto, Auto, Auto, Auto, Auto">
      <Label
          Grid.Row="0"
          Grid.ColumnSpan="2"
          Style="{StaticResource GroupTitle}"
          Text="{Binding Caption, Source={x:Reference Root}}" />
      <Label
          Grid.Row="1"
          Grid.ColumnSpan="2"
          Style="{StaticResource FieldValue}"
          Text="{Binding Description, Source={x:Reference Root}}" />
      <BoxView
          Grid.Row="2"
          Grid.ColumnSpan="2"
          Style="{StaticResource HorizontalDivider}" />
      <Label
          Grid.Row="3"
          Grid.ColumnSpan="2"
          Style="{StaticResource FieldValue}"
          Text="{Binding Example, Source={x:Reference Root}}" />
      <Entry
          Grid.Row="4"
          Text="{Binding Value, Source={x:Reference Root}}" />
      <Button
          Grid.Row="4"
          Grid.Column="1"
          Command="{Binding ResetCommand, Source={x:Reference Root}}"
          Style="{StaticResource DeleteAdorner}" />
    </Grid>
  </Border>
</ContentView>
