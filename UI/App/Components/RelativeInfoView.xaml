<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="GT4.UI.Components.RelativeInfoView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:GT4.UI.Components"
    xmlns:dto="clr-namespace:GT4.Core.Project.Dto;assembly=GT4.Core.Project"
    x:Name="Root">

  <ContentView.Resources>
    <ResourceDictionary>
      <OnIdiom
          x:Key="VerticalLineMargin"
          x:TypeArguments="Thickness"
          Default="10,0,0,0"
          Phone="7.5,0,0,0" />
      <OnIdiom
          x:Key="HorizontalLineMargin"
          x:TypeArguments="Thickness"
          Default="10,40,0,0"
          Phone="7.5,40,0,0" />
      <OnIdiom
          x:Key="RelativesMargin"
          x:TypeArguments="Thickness"
          Default="20,0,0,0"
          Phone="15,0,0,0" />
    </ResourceDictionary>
  </ContentView.Resources>

  <Grid
      ColumnDefinitions="Auto, *, Auto"
      RowDefinitions="Auto, Auto, *">

    <Label
        Grid.Row="0"
        Grid.Column="0"
        Style="{StaticResource FieldValue}"
        Text="{Binding RelationTypeName, Source={x:Reference Root}}"
        VerticalOptions="Start" />

    <Label
        Grid.Row="0"
        Grid.Column="1"
        IsVisible="{Binding ShowDate, Source={x:Reference Root}}"
        Style="{StaticResource FieldValue}"
        Text="{Binding RelationshipDate, Source={x:Reference Root}}"
        VerticalOptions="Start" />

    <components:PersonInfoView
        Grid.Row="1"
        Grid.Column="0"
        Grid.ColumnSpan="2"
        DatesLabelStyle="{StaticResource FieldValue}"
        NameLabelStyle="{StaticResource FieldName}"
        Person="{Binding Relative, Source={x:Reference Root}}"
        Style="{StaticResource HoverItem}" />

    <Button
        x:Name="MoreBtn"
        Grid.Row="1"
        Grid.Column="2"
        Command="{Binding ShowMoreRelativesCommand, Source={x:Reference Root}}"
        IsVisible="{Binding ShowMoreButton, Source={x:Reference Root}}"
        Style="{StaticResource EmojiAdorner}"
        Text="{Binding MoreBtnName, Source={x:Reference Root}}"
        VerticalOptions="Fill"
        WidthRequest="{Binding Height, Source={x:Reference MoreBtn}}" />

    <BoxView
        Grid.Row="2"
        Grid.Column="0"
        Margin="{StaticResource VerticalLineMargin}"
        HorizontalOptions="Start"
        IsVisible="{Binding ShowRelatives, Source={x:Reference Root}}"
        VerticalOptions="Fill"
        WidthRequest="1"
        Color="Gray" />

    <CollectionView
        Grid.Row="2"
        Grid.Column="0"
        Grid.ColumnSpan="3"
        HorizontalOptions="Fill"
        IsVisible="{Binding ShowRelatives, Source={x:Reference Root}}"
        ItemsSource="{Binding Relatives, Source={x:Reference Root}}">
      <CollectionView.ItemsLayout>
        <LinearItemsLayout
            ItemSpacing="{StaticResource PageContentSpacing}"
            Orientation="Vertical" />
      </CollectionView.ItemsLayout>

      <CollectionView.ItemTemplate>
        <DataTemplate x:DataType="dto:RelativeInfo">
          <Grid>
            <BoxView
                Margin="{StaticResource HorizontalLineMargin}"
                HeightRequest="1"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                WidthRequest="{Binding X, Source={x:Reference RelativeInfoView}}"
                Color="Gray" />

            <components:RelativeInfoView
                x:Name="RelativeInfoView"
                Margin="{StaticResource RelativesMargin}"
                PersonBirthDate="{Binding Relative.BirthDate, Source={x:Reference Root}}"
                Relative="{Binding .}"
                ShowMoreButton="True">

              <!--  TODO  -->
              <!--<components:RelativeInfoView.GestureRecognizers>
              <TapGestureRecognizer
                  Command="{Binding Path=PageCommand, Source={x:Reference Root}}"
                  CommandParameter="{Binding .}" />
              </components:RelativeInfoView.GestureRecognizers>-->

            </components:RelativeInfoView>
          </Grid>
        </DataTemplate>
      </CollectionView.ItemTemplate>
    </CollectionView>

  </Grid>
</ContentView>
